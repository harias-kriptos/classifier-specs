{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",

      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo nextest:*)",
      "Bash(cargo tarpaulin:*)",
      "Bash(cargo machete:*)",

      "Bash(make:*)",
      "Bash(./scripts/*)",
      "Bash(bash scripts/*)",
      "Bash(./scripts/bootstrap.sh:*)",

      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",

      "Read(./**)",
      "Read(~/.cargo/registry/**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./evals/**)",
      "Edit(./specs/**)",
      "Edit(./docs/**)",
      "Edit(./scripts/**)",
      "Edit(./.claude/**)",
      "Edit(./Cargo.toml)",
      "Edit(./Cargo.lock)",
      "Edit(./README.md)",
      "Edit(./CHANGELOG.md)",
      "Edit(./todo.md)"
    ],
    "ask": [
      "Bash(cargo install:*)",
      "Bash(cargo update:*)",
      "Bash(cargo publish:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr:*)",
      "Edit(./Dockerfile)",
      "Edit(./.github/**)",
      "Edit(./rust-toolchain.toml)",
      "Edit(./sonar-project.properties)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(eval:*)",

      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.kube/config)",
      "Read(~/.netrc)",
      "Read(~/.gnupg/**)",
      "Read(~/.docker/config.json)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",

      "Edit(./.env)",
      "Edit(./.git/**)",
      "Edit(./target/**)",

      "WebFetch(domain:*)"
    ]
  },

  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "./target",
        "./.cargo-cache",
        "~/.cargo/registry/cache",
        "~/.cargo/registry/index",
        "/tmp"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.kube",
        "~/.gnupg",
        "~/.netrc",
        "~/Library/Keychains",
        "~/Library/Application Support/com.apple.TCC",
        "./.env",
        "./.env.local"
      ],
      "allowRead": [
        ".",
        "~/.cargo",
        "~/.rustup"
      ]
    },
    "network": {
      "allowManagedDomainsOnly": true,
      "allowedDomains": [
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "*.crates.io",
        "static.rust-lang.org",
        "rust-lang.org",
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org"
      ],
      "deniedDomains": [
        "169.254.169.254",
        "metadata.google.internal",
        "instance-data.ec2.internal"
      ]
    },
    "excludedCommands": [
      "docker *",
      "docker-compose *",
      "kubectl *"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-bootstrap-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-main-branch.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-secrets.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-commands.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-rust.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-tdd-trace.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },

  "env": {
    "CLAUDE_TDD_STRICT": "true",
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always",
    "AWS_PROFILE": "__BLOCKED__",
    "AWS_ACCESS_KEY_ID": "__BLOCKED__",
    "AWS_SECRET_ACCESS_KEY": "__BLOCKED__"
  }
}
