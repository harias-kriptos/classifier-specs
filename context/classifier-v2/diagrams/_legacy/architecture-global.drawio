        <mxCell id="ext-signal" value="Signal Handler&#10;[External Service]&#10;&#10;Pushes cycle payload to active Agents (Fase 2 sampling request)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#52525B;strokeColor=#27272A;fontColor=#ffffff;fontSize=13;align=center;verticalAlign=middle;dashed=1;dashPattern=8 4;strokeWidth=2;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="2330" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ext-bedrock" value="Bedrock&#10;[AWS AI/ML]&#10;&#10;Generates 2K-5K keywords per enterprise (manual trigger)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#52525B;strokeColor=#27272A;fontColor=#ffffff;fontSize=13;align=center;verticalAlign=middle;dashed=1;dashPattern=8 4;strokeWidth=2;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="2900" y="2330" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ext-anon" value="Anonymizer&#10;[External Service]&#10;&#10;Removes PII from raw samples. Reads gse-raw, writes gse-anonymized" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#52525B;strokeColor=#27272A;fontColor=#ffffff;fontSize=13;align=center;verticalAlign=middle;dashed=1;dashPattern=8 4;strokeWidth=2;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="2300" y="2330" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ext-llm" value="LLM Process Queue&#10;[External Service]&#10;&#10;Reads anonymized samples, generates final classification labels" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#52525B;strokeColor=#27272A;fontColor=#ffffff;fontSize=13;align=center;verticalAlign=middle;dashed=1;dashPattern=8 4;strokeWidth=2;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="5500" y="2330" width="280" height="200" as="geometry" />
