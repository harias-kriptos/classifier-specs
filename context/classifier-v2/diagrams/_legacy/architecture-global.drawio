        <mxCell id="sm-ddb-label" value="classifier-cycles-state&#10;━━━━━━━━━━━━━━&#10;PK: enterprise_id&#10;SK: CYCLE# / STATION# / REQUEST#&#10;━━━━━━━━━━━━━━&#10;TTL: 90d after complete" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontColor=#1E40AF;fontStyle=1;" vertex="1" parent="1">
