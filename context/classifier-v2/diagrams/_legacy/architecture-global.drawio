        <!-- Yellow note -->
        <mxCell id="note-f1s" value="Flujo Fase 1:&#10;&#10;1. Windows Agent → POST /v2/tree/init → presigned URL&#10;2. Agent PUT .jsonl.gz a compressed_trees&#10;3. tree-uncompressor descomprime → decompressed_trees&#10;4. emr-job-trigger lanza Spark (joyas-priorizer)&#10;5. crown-candidates-indexer bulk index + crea CYCLE&#10;6. crown-enterprise-barrier espera todos los STATIONs&#10;&#10;Cloud Agent escribe directo a decompressed_trees (skip 1-3)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#FBC02D;fontColor=#5D4037;fontSize=13;align=left;verticalAlign=top;strokeWidth=2;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
