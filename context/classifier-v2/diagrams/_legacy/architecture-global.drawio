        <mxCell id="bg-ext-title" value="5.  EXTERNAL SYSTEMS (black boxes)" style="text;html=1;strokeColor=none;fillColor=#52525B;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#ffffff;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="40" y="2260" width="6720" height="36" as="geometry" />
