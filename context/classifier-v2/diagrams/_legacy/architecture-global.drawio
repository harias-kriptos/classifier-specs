        <mxCell id="note-validation" value="Validación humana (human-in-the-loop):&#10;&#10;Cliente revisa candidatos en la UI:&#10;  ✓ Approve (mantiene en lista)&#10;  ✗ Reject (descarta)&#10;  + Add manual (agrega nuevos)&#10;&#10;Al confirmar:&#10;  • Materializa manifest.json con files_to_sample&#10;  • CYCLE pasa a 'confirmed'&#10;  • O 'phase2_skipped' si 0 aprobados" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#FBC02D;fontColor=#5D4037;fontSize=13;align=left;verticalAlign=top;strokeWidth=2;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="1000" width="500" height="180" as="geometry" />
        </mxCell>

        <!-- ============ LANE 4 — STATE MACHINE (PROMINENTE) ============ -->
        <mxCell id="bg-sm" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="1220" width="6720" height="560" as="geometry" />
        </mxCell>
        <mxCell id="bg-sm-title" value="★  STATE MACHINE  ★     ·     Compartido por las 3 fases     ·     Single source of truth     ·     DynamoDB conditional writes para exactly-once" style="text;html=1;strokeColor=none;fillColor=#D97706;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#ffffff;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="40" y="1220" width="6720" height="44" as="geometry" />
        </mxCell>

        <mxCell id="sm-states-note" value="CYCLE state machine&#10;&#10;1. scanning&#10;       ↓ (crown-barrier)&#10;2. stations_complete&#10;       ↓ (validation-mutation)&#10;       (UI: approve/reject)&#10;       ↓ (crown-validation-confirm)&#10;3. confirmed&#10;       ↓ (gse-cycle-init)&#10;4. phase2_collecting&#10;       ↓ (gse-enterprise-status)&#10;5. complete&#10;&#10;Alternativa:&#10;3. confirmed → phase2_skipped&#10;       (si 0 aprobados)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#D97706;fontColor=#78350F;fontSize=13;align=left;verticalAlign=top;strokeWidth=2;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="1290" width="400" height="440" as="geometry" />
        </mxCell>

