        <mxCell id="sm-idempotency-note" value="Exactly-once semantics:&#10;&#10;DDB Stream entrega registros&#10;at-least-once (puede duplicar).&#10;&#10;Garantía exactly-once con&#10;conditional DDB writes:&#10;&#10;Per-STATION barrier flag:&#10;  SET barrier_counted = true&#10;  IF barrier_counted &lt;&gt; true&#10;&#10;CYCLE counter increment:&#10;  ADD stations_completed = 1&#10;  IF status = 'scanning'&#10;&#10;Barrier condition (Fase 2):&#10;  samples_anonymized&#10;  + samples_skipped&#10;  &gt;= samples_expected&#10;&#10;Si conditional falla&#10;→ ya procesado, ignorar." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#D97706;fontColor=#78350F;fontSize=13;align=left;verticalAlign=top;strokeWidth=2;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="6200" y="1290" width="500" height="440" as="geometry" />
        </mxCell>

