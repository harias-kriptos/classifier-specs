        <mxCell id="footer-state3" value="EventBridge Pipes filtran por atributo (no solo SK prefix): KT-17025 por scan_status=complete · KT-17032 por sampling_status existe · KT-17033 por status=phase2_collecting → cada state lambda solo ve su fase" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#5f6368;" vertex="1" parent="1">
